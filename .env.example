# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=your-convex-deployment-name # team: your-team-name, project: your-project-name

NEXT_PUBLIC_CONVEX_URL=https://your-convex-deployment-name.convex.cloud

NEXT_PUBLIC_CONVEX_SITE_URL=https://your-convex-deployment-name.convex.site

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key
CLERK_SECRET_KEY=sk_test_your-secret-key

CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-issuer-domain.clerk.accounts.dev